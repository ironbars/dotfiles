"Basic configuration
"===================
set nocompatible
set termguicolors
syntax on
let mapleader=","
set backspace=indent,eol,start
"always let the last window have a status line
set laststatus=2
set ruler
set number

"Indentation settings
"====================
set tabstop=4
set shiftwidth=4
set expandtab
set smarttab
filetype plugin indent on

"Search settings
"===============
set showmatch
set ignorecase
set smartcase
set incsearch
set hlsearch
nnoremap <silent> <leader>q :nohlsearch<CR>

"Custom command for fzf and ripgrep
"command! -bang -nargs=* Search call fzf#vim#grep(
"  \ 'rg --line-number --no-heading --fixed-strings --ignore-case
"  \ --no-ignore --hidden --follow --glob "!.git/*" --color "always" '
"  \ . shellescape(<q-args>), 0, <bang>0)

"Extra key bindings
"==================
nnoremap j gj
nnoremap k gk
nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-h> <C-W>h
nnoremap <C-l> <C-W>l
"edit and source vimrc on the fly
nnoremap <leader>ev :split $MYVIMRC<CR>
nnoremap <leader>sv :source $MYVIMRC<CR>
"open buffers for selection
nnoremap <leader>b :ls<CR>:b<space>
"newlines
nnoremap <leader>o o<esc>"_D
nnoremap <leader>j i<CR><esc>
"open fzf file search
"nnoremap <leader>fs :Files<CR>
"open rg and fzf to search inside files
"nnoremap <leader>s :Search<space>
"change word to uppercase
inoremap <C-u> <esc>viwUea

"Syntax highlighting (for strange extensions)
"============================================
augroup filetype_cmds
  autocmd!
  autocmd BufRead,BufNewFile *.sage set filetype=python
  autocmd BufRead,BufNewFile *.adoc set filetype=asciidoc
  autocmd BufRead,BufNewFile *bashrc* set filetype=sh
  autocmd BufRead,BufNewFile *bash_* set filetype=sh
  autocmd BufRead,BufNewFile *.pp set filetype=puppet
  autocmd BufRead,BufNewFile poetry.lock set filetype=toml
augroup END

"let g:airline_theme = 'ravenpower'
"let g:airline_theme = 'apprentice'
"let g:airline_theme='owo'

{{ if eq .class "home" -}}
"Plugins
"=======
call plug#begin('~/.config/vim/addons')
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'junegunn/fzf', {'do': { -> fzf#install() }}
Plug 'junegunn/fzf.vim'
Plug 'vimwiki/vimwiki'
Plug 'alok/notational-fzf-vim'

"syntax
Plug 'keysmashes/vim-lilypond'
Plug 'google/vim-jsonnet'

"colors
Plug 'romainl/Apprentice', {'as': 'apprentice'}
Plug 'nordtheme/vim', {'as': 'nord'}
Plug 'jnurmine/Zenburn', {'as': 'zenburn'}
Plug 'altercation/vim-colors-solarized', {'as': 'solarized'}
call plug#end()

"Plugin configurations
"=====================
let g:nv_search_paths = ['~/notes']
let g:nv_create_note_key = 'ctrl-n'
let g:nv_create_if_no_results = 1
let g:nv_create_note_window = 'edit'
let g:vimwiki_list = [{ 'path': '~/notes', 'syntax': 'markdown', 'ext': 'md'}]
let g:vimwiki_global_ext = 0
let g:vimwiki_ext2syntax = {'.md': 'markdown', '.markdown': 'markdown'}

nnoremap <leader>n :NV<CR>
{{- end }}

"Colors
"======
"colorscheme apprentice
colorscheme nord
"colorscheme solarized
"colorscheme zenburn
