{{- if lookPath "starship" -}}
# starship
# --------
source <(starship init {{ .shell }})
{{ end }}
{{- if lookPath "fzf" }}
# fzf
# ---
export FZF_DEFAULT_OPTS_FILE="${HOME}/.config/fzf/config"
{{-   if lookPath "rg" }}
export FZF_DEFAULT_COMMAND="rg --files --no-ignore --hidden --follow --glob '!.git/*'"
{{-   end }}

source <(fzf --{{ .shell }})

fc() {
  local dir

  dir="$(
    find "${1:-.}" -path '*/\.*' -prune -o -type d -print 2> /dev/null | fzf +m
  )" && cd "${dir}"
}
{{ end }}
{{- if lookPath "zoxide" }}
# zoxide
# ------
export _ZO_DATA_DIR="${HOME}/.local/share/zoxide"

source <(zoxide init {{ .shell }})

zl() {
  z "$@" && ls
}
{{ end }}
{{- if eq .editor "nvim" }}
# neovim
# ------
alias vim="nvim"
{{ end }}
